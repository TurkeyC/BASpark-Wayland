<Window x:Class="BASpark.LanguageSelectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="420" Width="460"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Topmost="True" Background="White" Icon="app.ico">

    <Window.Resources>
        <Style x:Key="RoundedBtn" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="LangOption" TargetType="RadioButton">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Margin" Value="0,6"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="120"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="90"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#45AFFF">
            <StackPanel VerticalAlignment="Center" Margin="24,0">
                <TextBlock x:Name="TxtTitle" FontSize="22" FontWeight="Bold" Foreground="White" TextWrapping="Wrap"/>
                <TextBlock x:Name="TxtSubtitle" FontSize="12" Foreground="#E8F4FF" Margin="0,10,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Margin="40,28,40,0">
            <RadioButton x:Name="RadioChinese" Style="{StaticResource LangOption}" GroupName="Lang" IsChecked="True"
                         Content="简体中文" Tag="zh-CN"/>
            <RadioButton x:Name="RadioEnglish" Style="{StaticResource LangOption}" GroupName="Lang"
                         Content="English" Tag="en"/>
            <RadioButton x:Name="RadioJapanese" Style="{StaticResource LangOption}" GroupName="Lang"
                         Content="日本語" Tag="ja"/>
        </StackPanel>

        <Border Grid.Row="2" BorderBrush="#EDF2F7" BorderThickness="0,1,0,0">
            <Button x:Name="BtnContinue" Click="BtnContinue_Click" Width="160" Height="44"
                    Background="#45AFFF" Foreground="White" Style="{StaticResource RoundedBtn}"
                    FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Cursor="Hand"/>
        </Border>
    </Grid>
</Window>
